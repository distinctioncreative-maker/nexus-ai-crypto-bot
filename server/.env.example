# Server Environment Variables
# Copy this file to server/.env and fill in your values

# ── Required ─────────────────────────────────────────────────────────────────

# Supabase (get from supabase.com → Project Settings → API)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # service_role key (keep secret — server only)

# Encryption key for Coinbase API keys stored in DB
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SECRET=

# Frontend URL for CORS — set to your deployed frontend domain in production
FRONTEND_URL=http://localhost:5173

# Groq AI — required for AI trading decisions, Oracle chat, and agent autopsies
# Free tier available at https://console.groq.com
GROQ_API_KEY=gsk_...

# ── Optional ─────────────────────────────────────────────────────────────────

# Groq model override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Public Coinbase Exchange WebSocket feed (do NOT use Advanced Trade WS here —
# this endpoint requires no auth and provides public ticker data)
MARKET_WS_URL=wss://ws-feed.exchange.coinbase.com

# E2E test credentials — only set in local dev / CI, never commit real values
# E2E_APP_URL=http://localhost:5173
# E2E_BACKEND_URL=http://localhost:3001
# E2E_EMAIL=test@example.com
# E2E_PASSWORD=
